MONGO_URL=mongodb://root:CHANGE_ME@your-mongo-host:27017/?directConnection=true

# Gemini API keys (load balanced round-robin — add up to 5)
GEMINI_API_KEY_1=your_api_key_1_here
GEMINI_API_KEY_2=your_api_key_2_here
GEMINI_API_KEY_3=your_api_key_3_here

# CORS — comma-separated list of allowed frontend origins
# Defaults to production + localhost if not set
ALLOWED_ORIGINS=https://redpen.tashanwin.buzz,http://localhost:5173,http://localhost:4173
